# Brevo (ex-Sendinblue) - https://app.brevo.com/settings/keys/smtp
# Seu email de login da conta Brevo
BREVO_USER=seuemail@gmail.com

# Chave SMTP gerada em: Brevo > Configurações > Chaves SMTP e API
BREVO_SMTP_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx

# Email que aparece como remetente (pode ser qualquer email verificado no Brevo)
BREVO_FROM=contato@gvpcontabilidade.com.br

# Email da GVP que vai receber as notificações de contato do site
RECIPIENT=gvpcontabilidade@hotmail.com

# Porta do servidor
PORT=3000